#!/bin/sh

set -e

_host_arch="$(uname -p)"
#_bricoler_test_task=freebsd-regression-test-suite-ci
_bricoler_test_task=freebsd-regression-test-suite

while getopts cib:k:m:n:p:t: name
do
  case "${name}" in
    c) _clean='--freebsd-src-build/clean=True' ;;
    i) _interactive="--${_bricoler_test_task}/interactive=True" ;;
    b) _branch="${OPTARG}" ;;
    k) _kernconf="${OPTARG}" ;;
    m) _klds="--freebsd-vm-image/rc_kld_list=${OPTARG}" ;;
    n) _count="--${_bricoler_test_task}/count=${OPTARG}" ;;
    p) _packages="--freebsd-vm-image/packages=${OPTARG}" ;;
    t) _target_arch="${OPTARG}" ;;
    ?)
      echo "Usage: $0: RTFM" >&2
      exit 64 # EX_USAGE
      ;;
    *) ;;
  esac
done
shift $((OPTIND - 1))
: ${_branch:=main}
: ${_target_arch:=${_host_arch}}
: ${_kernconf:=GENERIC}

case "${_target_arch}" in
  armv7)
    _machine='--freebsd-src-build/machine=arm/armv7'
    _hypervisor="--${_bricoler_test_task}/hypervisor=qemu"
    ;;
  aarch64)
    _machine='--freebsd-src-build/machine=arm64/aarch64'
    _hypervisor="--${_bricoler_test_task}/hypervisor=qemu"
    ;;
  amd64)
    _machine='--freebsd-src-build/machine=amd64/amd64'
    _hypervisor="--${_bricoler_test_task}/hypervisor=bhyve"
    ;;
  powerpc64)
    _machine='--freebsd-src-build/machine=powerpc/powerpc64'
    _hypervisor="--${_bricoler_test_task}/hypervisor=qemu"
    ;;
  powerpc64le)
    _machine='--freebsd-src-build/machine=powerpc/powerpc64le'
    _hypervisor="--${_bricoler_test_task}/hypervisor=qemu"
    ;;
  riscv64)
    _machine='--freebsd-src-build/machine=riscv/riscv64'
    #_hypervisor="--${_bricoler_test_task}/hypervisor=rvvm"
    _hypervisor="--${_bricoler_test_task}/hypervisor=qemu"
    ;;
  *) ;;
esac

#if test "${_host_arch}" = "${_target_arch}" -a "${_branch}" = main; then
#  _repo="--freebsd-vm-image/package_repo_file=/usr/local/etc/pkg/repos/siva-ports.conf"
#else
#  _repo="--freebsd-vm-image/package_repo_file=${HOME}/freebsd-ports.repo.conf"
#fi

# TODO "broken" testcases cause the command to pass, which is incorrect
# TODO set option for choosing toolchain, currently hardcoding to llvm21
#--freebsd-src-build/make_options='WITHOUT_LLDB= WITHOUT_LIB32= WITHOUT_ZFS_TESTS=' \
#
/home/siva/src/playground/venv/bin/bricoler \
${_bricoler_test_task} \
--freebsd-src-git-checkout/url=${HOME}/f/${_branch} \
--freebsd-src-git-checkout/branch= \
--freebsd-src-build/kernel_config=${_kernconf} \
--freebsd-src-build/toolchain=llvm21 \
--${_bricoler_test_task}/memory=3072 \
--${_bricoler_test_task}/ncpus=2 \
--${_bricoler_test_task}/parallelism=1 \
${_machine} \
${_hypervisor} \
${_clean} \
${_interactive} \
${_count} \
${_klds} \
${_packages} \
${_repo} \
--${_bricoler_test_task}/tests=$1

#printf '========== SIVA BRICOLER ==========\n%s\n===================================\n' "${_cmd}"
#${_cmd} || exit 125 # git bisect skip

#/home/siva/src/playground/venv/bin/bricoler ${_bricoler_test_task} report | \
#  { ! grep -q "${test_to_bisect}  ->  "; }
